<?xml version="1.0"?>
<robot name="servo_demo">

  <link name="world"/>

  <link name="base_link">
    <visual>
      <geometry>
        <box size="0.12 0.12 0.03"/>
      </geometry>
    </visual>
  </link>

  <joint name="world_to_base" type="fixed">
    <parent link="world"/>
    <child link="base_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <link name="arm_link">
    <visual>
      <origin xyz="0.10 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.20 0.03 0.03"/>
      </geometry>
    </visual>
  </link>

  <joint name="servo_joint" type="revolute">
    <parent link="base_link"/>
    <child link="arm_link"/>
    <origin xyz="0 0 0.03" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="0.0" upper="3.14159" effort="1.0" velocity="2.0"/>
  </joint>

</robot>